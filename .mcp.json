{
  "mcpServers": {
    "claude-flow": {
      "command": "npx",
      "args": [
        "-y",
        "ruflo@latest",
        "mcp",
        "start"
      ],
      "env": {
        "npm_config_update_notifier": "false",
        "CLAUDE_FLOW_MODE": "v3",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDE_FLOW_TOPOLOGY": "hierarchical-mesh",
        "CLAUDE_FLOW_MAX_AGENTS": "15",
        "CLAUDE_FLOW_MEMORY_BACKEND": "hybrid"
      },
      "autoStart": false
    },
    "toriigate": {
      "command": "/home/datdang/working/lnd_dev/.venv/bin/python",
      "args": [
        "/home/datdang/working/lnd_dev/playground/toriigate/mcp_server.py"
      ],
      "env": {
        "TORIIGATE_API_URL": "http://127.0.0.1:1234",
        "TORIIGATE_NGL": "99",
        "TORIIGATE_NCTX": "8192"
      },
      "autoStart": false
    }
  }
}