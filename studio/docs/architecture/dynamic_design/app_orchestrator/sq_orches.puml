@startuml sq_orches

title LND Orchestrator - Gooner Alchemist Pipeline (V7.0)

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 250
skinparam BoxPadding 10

actor "User" as user
box "APP Layer (Control Plane)" #LightBlue
  participant "Director K\n(Orchestrator)" as orches
  participant "Task Planner\n(Tool: sequential-thinking)" as planner
end box

box "SERVICE Layer (Specialists)" #LightYellow
  participant "Dr. Atomic\n(Forensics)" as agent_atomic
  participant "Suki\n(Lewd Writer)" as agent_suki
  participant "Riko\n(Quality Audit)" as agent_riko
end box

== 1. Intent & Planning ==

user -> orches : "Run Gooner Alchemist"
activate orches

orches -> planner : **Create Task Graph**\n(Goal: Process Pending Pages)
activate planner
planner --> orches : Execution Plan:\n1. Init & Horizon\n2. Forensics (Atomic)\n3. Prose (Suki)\n4. Audit (Riko)
deactivate planner

== 2. Execution Phase (8-Step Pipeline) ==

group Step 1-1b: Initialization & Horizon
    orches -> orches : **Load Pipeline Context**
    orches -> orches : **Check State / Horizon Check**\n(Generate Context Horizon)
end

group Step 2: Forensic Analysis
    orches -> agent_atomic : **DELEGATE TASK**\n"Run Panel Forensic Scan"
    activate agent_atomic
    agent_atomic --> orches : **Forensic Report**\n(10 Sections)
    deactivate agent_atomic
end

group Step 3-4: Context Loading & Prose Generation
    orches -> orches : **Compile JIT Context**
    orches -> agent_suki : **DELEGATE TASK**\n"Draft Prose (Using Forensic + Bibles)"
    activate agent_suki
    agent_suki --> orches : **Draft Markdown Text**
    deactivate agent_suki
end

group Step 5: Quality Gate
    orches -> agent_riko : **DELEGATE TASK**\n"Audit Output (Score 0-100)"
    activate agent_riko
    
    alt Audit Pass
        agent_riko --> orches : "PASS (Score > threshold)"
    else Audit Fail
        agent_riko --> orches : "FAIL (Issues List)"
        orches -> agent_suki : **RE-DELEGATE**\n"Fix Targeted Issues: [List]"
    end
    deactivate agent_riko
end

group Step 6-7: Persistence & Complete
    orches -> orches : **Save State & Ledger**
    orches -> planner : Update Status (Page Done)
end

== 3. Completion ==

orches -> user : "Pipeline Execution Complete"
deactivate orches

@enduml
