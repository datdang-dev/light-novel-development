{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "DraftProse",
    "description": "Output schema for Draft Prose produced by Suki.",
    "type": "object",
    "properties": {
        "page_number": {
            "type": "string"
        },
        "prose_content": {
            "type": "string"
        },
        "word_count": {
            "type": "integer"
        },
        "metrics": {
            "type": "object",
            "properties": {
                "smell_mentions": {
                    "type": "integer"
                },
                "sound_mentions": {
                    "type": "integer"
                },
                "texture_mentions": {
                    "type": "integer"
                },
                "temperature_mentions": {
                    "type": "integer"
                }
            },
            "additionalProperties": false
        },
        "format_compliance": {
            "type": "object",
            "properties": {
                "has_header": {
                    "type": "boolean"
                },
                "has_footer": {
                    "type": "boolean"
                },
                "valid_dialogue_format": {
                    "type": "boolean"
                },
                "valid_sfx_format": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false
        },
        "sensory_affect": {
            "type": "object",
            "properties": {
                "olfactory": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "tactile": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "visual": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "dialogue_escalation": {
                    "type": "string"
                },
                "tsundere_breakdown": {
                    "type": "number",
                    "minimum": 0.0,
                    "maximum": 10.0
                },
                "stroking_metric": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 10
                }
            },
            "required": [
                "olfactory",
                "tactile",
                "visual",
                "dialogue_escalation",
                "tsundere_breakdown",
                "stroking_metric"
            ],
            "additionalProperties": false
        }
    },
    "required": [
        "page_number",
        "prose_content",
        "word_count",
        "metrics",
        "format_compliance",
        "sensory_affect"
    ],
    "additionalProperties": false
}