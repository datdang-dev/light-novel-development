{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ForensicState",
    "description": "Standardized intermediate format produced by Kana or Ren'Py adapter, representing the scene's starting state.",
    "type": "object",
    "properties": {
        "page_number": {
            "type": "string"
        },
        "content_tags": {
            "type": "array",
            "description": "Used by JIT RAG system to fetch relevant research files.",
            "items": {
                "type": "string"
            }
        },
        "characters_present": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "setting": {
            "type": "object",
            "properties": {
                "location": {
                    "type": "string"
                },
                "time": {
                    "type": "string"
                },
                "atmosphere": {
                    "type": "string"
                }
            },
            "required": [
                "location"
            ],
            "additionalProperties": false
        },
        "panels": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "panel_number": {
                        "type": "integer"
                    },
                    "description": {
                        "type": "string"
                    },
                    "action": {
                        "type": "string"
                    }
                },
                "required": [
                    "panel_number",
                    "description"
                ],
                "additionalProperties": false
            }
        },
        "dialogue": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "speaker": {
                        "type": "string"
                    },
                    "text_original": {
                        "type": "string"
                    },
                    "text_translated": {
                        "type": "string"
                    },
                    "context": {
                        "type": "string"
                    }
                },
                "required": [
                    "speaker",
                    "text_translated"
                ],
                "additionalProperties": false
            }
        },
        "sfx": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "original": {
                        "type": "string"
                    },
                    "romanized": {
                        "type": "string"
                    },
                    "lewd_equivalent": {
                        "type": "string"
                    }
                },
                "required": [
                    "romanized"
                ],
                "additionalProperties": false
            }
        },
        "explicit_elements": {
            "type": "object",
            "description": "R18 elements: acts, exposure, fluids, and metadata. Canonical field — gate_registry and Pydantic model both reference this key.",
            "properties": {
                "acts": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Sexual acts detected (e.g., penetration, oral, groping)"
                },
                "exposure": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Exposed body parts (e.g., breasts, crotch)"
                },
                "fluids": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Fluids present (e.g., semen, saliva, sweat)"
                },
                "clothing_state": {
                    "type": "string"
                },
                "fluid_distribution": {
                    "type": "string"
                },
                "body_hair_noted": {
                    "type": "boolean"
                },
                "condoms_present": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false
        },
        "interactions": {
            "type": "array",
            "description": "Spatial interactions: who is doing what to whom. MANDATORY if explicit_elements.acts is non-empty.",
            "items": {
                "type": "object",
                "properties": {
                    "subject": {
                        "type": "string",
                        "description": "Entity performing the action (name, or PARTIALLY_OBSCURED / OFF_PANEL)"
                    },
                    "action": {
                        "type": "string",
                        "description": "Physical verb: licking, groping, restraining, penetrating, etc."
                    },
                    "target": {
                        "type": "string",
                        "description": "Entity receiving the action"
                    },
                    "body_part": {
                        "type": "string",
                        "description": "Specific body part involved"
                    },
                    "sensory_tags": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "modality": {
                                    "type": "string",
                                    "enum": ["smell", "texture", "temperature", "sound"]
                                },
                                "value": {
                                    "type": "string"
                                },
                                "certainty": {
                                    "type": "string",
                                    "enum": ["confirmed", "probable", "ambiguous"],
                                    "default": "probable"
                                }
                            },
                            "required": ["modality", "value"]
                        },
                        "minItems": 2
                    },
                    "power_dynamic": {
                        "type": "string",
                        "enum": ["dominant", "submissive", "mutual", "neutral"],
                        "default": "neutral"
                    },
                    "intensity": {
                        "type": "string",
                        "enum": ["LOW", "MED", "HIGH", "EXTREME"],
                        "default": "MED"
                    }
                },
                "required": ["subject", "action", "target", "body_part", "sensory_tags"]
            }
        },
        "sensory_extraction": {
            "type": "object",
            "properties": {
                "smells": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "sounds": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "textures": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "temperatures": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "additionalProperties": false
        },
        "evidence_ledger": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "claim": {
                        "type": "string"
                    },
                    "confidence_score": {
                        "type": "number",
                        "minimum": 0.0,
                        "maximum": 1.0
                    },
                    "evidence_type": {
                        "type": "string",
                        "enum": ["pixel_grounded", "verified_inference", "tag_suggested", "lore_assumed"]
                    },
                    "visibility": {
                        "type": "string",
                        "enum": ["visible", "partially_occluded", "not_visible", "absent"]
                    },
                    "source": {
                        "type": "string"
                    }
                },
                "required": ["claim", "confidence_score", "evidence_type", "visibility", "source"],
                "additionalProperties": false
            }
        }
    },
    "required": [
        "page_number",
        "content_tags",
        "characters_present",
        "setting",
        "panels"
    ],
    "additionalProperties": false
}